# Firebase Configuration
# Copy this file to .env and fill in your actual values
# Get these from: Firebase Console > Project Settings > General > Your apps > Web app

FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Business Configuration
WHATSAPP_NUMBER=919999999999
BUSINESS_PHONE=+91 99999 99999
BUSINESS_EMAIL=contact@dayalengineering.com
BUSINESS_ADDRESS=123 Industrial Area, Your City, State - 123456

# Website Configuration
SITE_NAME=Dayal Engineering
SITE_TAGLINE=Reliable Welding & Fabrication Solutions
SITE_URL=https://yourdomain.com
